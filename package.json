{
  "name": "",
  "version": "4.1.0",
  "scripts": {
    "dev": "npm run related:ensure && astro dev",
    "start": "npm run dev",
    "build": "npm run related:ensure && astro check && astro build && jampack ./dist",
    "preview": "astro preview",
    "sync": "astro sync",
    "astro": "astro",
    "related:check": "node scripts/related-posts.mjs check",
    "related:ensure": "node --env-file-if-exists=.env scripts/related-posts.mjs ensure",
    "related:generate": "node --env-file-if-exists=.env scripts/related-posts.mjs generate",
    "related:force": "node --env-file-if-exists=.env scripts/related-posts.mjs generate --force",
    "related:report": "node --env-file-if-exists=.env scripts/related-posts.mjs report",
    "format:check": "prettier --plugin-search-dir=. --check .",
    "format": "prettier --plugin-search-dir=. --write .",
    "cz": "cz",
    "prepare": "husky install",
    "lint": "eslint ."
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/partytown": "^2.1.7",
    "@astrojs/rss": "^4.0.19",
    "@resvg/resvg-js": "^2.6.0",
    "astro": "^7.0.7",
    "fuse.js": "^7.0.0",
    "github-slugger": "^2.0.0",
    "rehype-katex": "^7.0.0",
    "remark-collapse": "^0.1.2",
    "remark-math": "^6.0.0",
    "remark-toc": "^9.0.0",
    "satori": "^0.10.11",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "@astrojs/react": "^6.0.1",
    "@astrojs/sitemap": "^3.7.3",
    "@divriots/jampack": "^0.34.1",
    "@tailwindcss/typography": "^0.5.10",
    "@types/github-slugger": "^1.3.0",
    "@types/markdown-it": "^14.1.2",
    "@types/react": "^18.2.47",
    "@types/react-dom": "^18.3.0",
    "@types/sanitize-html": "^2.16.1",
    "@typescript-eslint/parser": "^6.18.1",
    "astro-eslint-parser": "^0.16.0",
    "autoprefixer": "^10.4.20",
    "commitizen": "^4.3.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^8.56.0",
    "eslint-plugin-astro": "^0.31.0",
    "gray-matter": "^4.0.3",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "markdown-it": "^14.3.0",
    "openai": "^6.46.0",
    "prettier": "^3.1.1",
    "prettier-plugin-astro": "^0.12.3",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sanitize-html": "^2.17.6"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,md,mdx,json}": [
      "prettier --plugin-search-dir=. --write"
    ]
  }
}
